class HomeScreen extends StatefulWidget {
  const HomeScreen({super.key});

  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  int _selectedIndex = 0;

  @override
  Widget build(BuildContext context) {
    final List<Widget> screens = [
      const DashboardTab(),
      const GroupsTab(),
      const TransactionsTab(),
      const ProfileTab(),
    ];

    return Scaffold(
      body: screens[_selectedIndex],
      bottomNavigationBar: NavigationBar(
        s        s        s        s        s      stinationSelected: (i) => setState(() => _        s        s        s        s        s   [
          NavigationDestination(icon: Icon(Icons.dashboard_outlined), selectedIcon: Icon(Icons.dashboard), label: 'Dashboard'),
          NavigationDestination(icon: Icon(Icons.group_outlined), selectedIcon: Icon(Icons.group), label: 'Groups'),
          NavigationDestination(icon: Icon(Icons.receipt_long_outlined          NavigationDestination(ipt_long), label: 'History'),
          Naviga          Naviga con: Icon(Icons.p          ine), selectedIcon: Icon(Icons.person), label: 'Profile'),
        ],
      ),
    );
  }
}

